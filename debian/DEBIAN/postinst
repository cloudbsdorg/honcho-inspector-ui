#!/bin/sh
set -e

case "$1" in
    install|configure)
        # Create the service user/group if missing. configure is
        # what dpkg invokes after `dpkg -i`; install is what some
        # higher-level tools use. Both mean "first-time setup is
        # safe to run".
        if ! getent group www-data >/dev/null; then
            addgroup --system www-data
        fi
        if ! getent passwd www-data >/dev/null; then
            adduser --system \
                --home /var/lib/honcho-inspector-ui \
                --no-create-home \
                --shell /usr/sbin/nologin \
                --ingroup www-data \
                --gecos "Honcho Inspector UI service account" \
                www-data
        fi
        # State, log, config directories with correct ownership and mode.
        install -d -m 0750 -o root -g www-data /var/lib/honcho-inspector-ui
        install -d -m 0750 -o root -g www-data /var/log/honcho-inspector-ui
        install -d -m 0750 -o root -g www-data /etc/honcho-inspector-ui
        # Make the shipped app tree readable by the service user.
        chown -R root:www-data /usr/local/share/honcho-inspector-ui
        find /usr/local/share/honcho-inspector-ui -type d \
            -exec chmod 0755 {} +
        find /usr/local/share/honcho-inspector-ui -type f \
            -exec chmod 0644 {} +
        if [ -d /usr/local/share/honcho-inspector-ui/node_modules/.bin ]; then
            find /usr/local/share/honcho-inspector-ui/node_modules/.bin \
                -type f -exec chmod 0755 {} +
        fi
        # Seed the proxy config ONLY if missing; the package is
        # idempotent and respects operator edits.
        if [ ! -f /etc/honcho-inspector-ui/proxy.conf.json ]; then
            install -m 0644 -o root -g www-data \
                /usr/local/share/honcho-inspector-ui/proxy.conf.json \
                /etc/honcho-inspector-ui/proxy.conf.json
        fi
        ;;
    upgrade)
        # Refresh permissions on upgrade (npm ci ran at install time).
        chown -R root:www-data /usr/local/share/honcho-inspector-ui
        find /usr/local/share/honcho-inspector-ui -type d \
            -exec chmod 0755 {} +
        find /usr/local/share/honcho-inspector-ui -type f \
            -exec chmod 0644 {} +
        ;;
    abort-upgrade)
        ;;
    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

if [ -d /run/systemd/system ]; then
    systemctl daemon-reload
fi

#DEBHELPER#

exit 0