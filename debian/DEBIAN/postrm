#!/bin/sh
set -e

# This postrm is invoked by fpm's debhelper-style wrapper. The wrapper
# handles "remove vs purge" dispatch via the `after_remove` /
# `after_purge` function scaffolding; we just put our cleanup
# logic here as flat commands.
#
# dpkg invokes this with $1=remove|purge|disappear $2=<old-version|empty>.

# No-op. State dirs (/var/lib, /var/log, /etc/honcho-inspector-ui)
# are preserved across uninstall so logs and operator config survive
# a reinstall. `dpkg --purge` does NOT auto-remove files that were
# created by the postinst (only files that came in the deb's data
# tarball), so the install is fully reversible without losing data.

exit 0