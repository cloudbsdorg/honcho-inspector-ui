# Containerfile for the honcho-inspector-ui Arch Linux package builder.
#
# Source base image:
#   docker.io/library/archlinux:latest -- the rolling Arch release.
#   Arch is the only distro in this matrix whose package manager
#   (pacman + makepkg) is the build tool itself; we do not need
#   fpm for the Arch artifact, so Ruby is also unnecessary. The
#   base image is already a minimal Arch root (~250 MB) with pacman
#   pre-installed, which keeps the layer cache small.
#
# Why no third-party repo is added:
#   Arch is a rolling distro and ships the latest of everything in
#   its main repos. `nodejs-lts-krypton` (Node 24.16.0), `ruby`
#   3.4.8, `fakeroot`, `base-devel` (gcc, make, fakeroot, etc.),
#   and `coreutils` are all in the `core` and `extra` repos. AUR
#   is not needed; nothing we use is out-of-tree.
#
# Why `fakeroot` is explicitly installed:
#   makepkg refuses to run as root (uid 0) -- it checks EUID and
#   aborts because building packages as root can damage the host.
#   We run makepkg as a non-root `build` user inside the entrypoint,
#   and fakeroot provides the fake root environment that lets the
#   `package()` function's `install -o root -g www-data` calls
#   record root ownership in the .pkg.tar.zst metadata even though
#   the actual on-disk files are owned by the build user.
#
# Artifact produced:
#   honcho-inspector-ui-0.1.0.SNAPSHOT-1-x86_64.pkg.tar.zst (a
#   zstd-compressed pacman package, built by makepkg against a
#   PKGBUILD we generate at build time). The leading "x86_64" is
#   the architecture string pacman inserts -- the package's
#   `arch=('x86_64')` setting is what puts it there. Written to
#   /out via the bind-mount contract:
#
#     podman run --rm \
#       -v $PWD:/src:ro -v $PWD/../dist:/out:rw \
#       --env HOST_UID=$(id -u) --env HOST_GID=$(id -g) \
#       honcho-inspector-ui:builder-arch
#
#   HOST_UID/HOST_GID default to 0:0 and are chowned by the
#   entrypoint at the end.

# ====== build =====================================================
FROM docker.io/library/archlinux:latest

LABEL org.opencontainers.image.title="honcho-inspector-ui:builder-arch" \
      org.opencontainers.image.description="Honcho Inspector UI Arch package builder (Arch rolling + Node 24 + makepkg)" \
      org.opencontainers.image.source="https://github.com/cloudbsdorg/honcho-inspector-ui" \
      org.opencontainers.image.licenses="BSD-3-Clause"

ARG HOST_UID=0
ARG HOST_GID=0

# Update first -- the archlinux:latest image's pacman db is stale
# within days and `pacman -Sy` inside a multi-RUN chain is a known
# footgun (partial upgrades); we keep it as a single combined
# command so the db + the install happen in one transaction.
#
# We install:
#   - base-devel: gcc, make, fakeroot, strip, binutils, gettext --
#     every tool makepkg expects to be present at build time.
#   - fakeroot: explicitly listed even though base-devel pulls it
#     transitively, because the entrypoint relies on `fakeroot`
#     being in $PATH.
#   - nodejs-lts-krypton (Node 24.16.0 in Arch's `extra` repo),
#     npm, ruby: all in main + extra.
#   - git: makepkg itself doesn't need git, but our PKGBUILD
#     references `pkgver()` derivation helpers that may want it;
#     cheap to include.
#   - openssl + libffi: ruby build needs them.
#   - coreutils: provides `runuser` (PAM-free `su` replacement).
RUN set -eux \
 && pacman -Syu --noconfirm --needed \
        base-devel \
        fakeroot \
        nodejs-lts-krypton \
        npm \
        ruby \
        git \
        openssl \
        libffi \
        coreutils \
 && pacman -Scc --noconfirm \
 && rm -rf /var/cache/pacman/pkg/*

# Bake the build entrypoint.
COPY packaging/build/arch/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod 0755 /usr/local/bin/entrypoint.sh

# Smoke-check the toolchain.
RUN node --version \
 && npm --version \
 && makepkg --version \
 && fakeroot --version

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD []
