# Containerfile for the honcho-inspector-ui Debian package builder.
#
# Source base image:
#   docker.io/library/debian:13-slim -- the current stable Debian
#   release ("trixie") on the slim variant. The slim image is the
#   right pick because (a) the build only needs ruby + ruby-dev +
#   fpm + the Node 24 toolchain (none of the GNOME/X11/server extras
#   the full debian:13 image ships), and (b) the slim variant is
#   ~30 MB vs. ~350 MB so the build cache stays small when the user
#   rebuilds after editing the entrypoint.
#
# Why a third-party repo (Nodesource) is added:
#   Debian 13 (trixie) ships Node 20 in its main archive. Angular 22
#   + Vite 5 require Node >= 20.19 but the production tooling chain
#   (the same engines constraint Angular's CLI enforces at runtime)
#   works best on Node 24, which is what every other distro in this
#   matrix also targets. Nodesource's setup_24.x script is the
#   upstream-blessed way to pull Node 24 onto a stock Debian host.
#   We use the modern signed-by=/etc/apt/keyrings/nodesource.gpg
#   form rather than the legacy apt-key path (deprecated in Debian 11
#   and removed in Debian 12); the GPG key is fetched with curl and
#   dearmored to disk so apt-get update never has to spawn gpg in a
#   pipeline.
#
# Artifact produced:
#   honcho-inspector-ui_0.1.0-SNAPSHOT_all.deb (a "dir" type .deb
#   built by fpm). It is NOT baked into the image -- the entrypoint
#   writes it to /out, which is bind-mounted from the host at run
#   time:
#
#     podman run --rm \
#       -v $PWD:/src:ro -v $PWD/../dist:/out:rw \
#       --env HOST_UID=$(id -u) --env HOST_GID=$(id -g) \
#       honcho-inspector-ui:builder-debian
#
#   The source tree is mounted read-only at /src. HOST_UID/HOST_GID
#   are passed via --env so the entrypoint can chown the produced
#   artifact back to the invoking user (default 0:0, i.e. root, when
#   the caller does not set them).

# ====== build =====================================================
FROM docker.io/library/debian:13-slim

LABEL org.opencontainers.image.title="honcho-inspector-ui:builder-debian" \
      org.opencontainers.image.description="Honcho Inspector UI Debian package builder (tri xie + Node 24 + fpm)" \
      org.opencontainers.image.source="https://github.com/cloudbsdorg/honcho-inspector-ui" \
      org.opencontainers.image.licenses="BSD-3-Clause"

# Build-arg defaulting to 0:0 keeps the image runnable as-is; the
# invocation contract above overrides them with the host UID/GID so
# the produced .deb is owned by the caller.
ARG HOST_UID=0
ARG HOST_GID=0

ENV DEBIAN_FRONTEND=noninteractive

# Install the build toolchain. Order matters for apt layer caching:
#   1. curl + ca-certificates + gnupg come first so the Nodesource
#      GPG key fetch below works on a fresh image.
#   2. ruby + ruby-dev + build-essential + libffi-dev + libssl-dev
#      are the gem prerequisites for fpm's native extensions
#      (mainly ffi-yajl and stud).
#   3. The Nodesource repo + Node 24 toolchain goes last because it
#      adds a third-party apt source that we want cached separately
#      from the distro packages.
RUN set -eux \
 && apt-get update \
 && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        gnupg \
        dirmngr \
        ruby \
        ruby-dev \
        build-essential \
        libffi-dev \
        libssl-dev \
 && install -d /etc/apt/keyrings \
 && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
        | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
 && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_24.x trixie main" \
        > /etc/apt/sources.list.d/nodesource.list \
 && apt-get update \
 && apt-get install -y --no-install-recommends \
        nodejs \
 && gem install --no-document fpm \
 && apt-get clean \
 && rm -rf /var/lib/apt/lists/*

# Bake the build entrypoint into the image. The entrypoint is
# responsible for staging /src and running fpm; the source tree
# itself is NEVER COPY'd in (the /src bind mount is the canonical
# source of truth, so we never cache a stale snapshot).
COPY packaging/build/debian/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod 0755 /usr/local/bin/entrypoint.sh

# Smoke-check the toolchain so a broken base image fails the build
# at image-creation time rather than at podman-run time.
RUN node --version \
 && npm --version \
 && ruby --version \
 && fpm --version

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD []
