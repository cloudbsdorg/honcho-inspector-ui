# Containerfile for the honcho-inspector-ui Alpine package builder.
#
# Source base image:
#   docker.io/library/alpine:3.23 -- Alpine ships Node 22 LTS in
#   v3.23 main (Node 22.23.0); we use that as the base. Alpine is
#   musl-based (vs glibc for the other distros in this matrix).
#
# We do NOT use fpm to build the apk -- fpm 1.17's apk builder is
# rejected by apk-tools 3.x with "unexpected end of file". Instead
# we invoke `apk mkpkg` directly. apk-tools is preinstalled in the
# Alpine base image so no extra install is required.
#
# Artifact produced:
#   honcho-inspector-ui-0.1.0-SNAPSHOT.apk
#   Written to /out at run time via the bind-mount contract:
#
#     podman run --rm \
#       -v $PWD:/src:ro -v $PWD/../dist:/out:rw \
#       --env HOST_UID=$(id -u) --env HOST_GID=$(id -g) \
#       honcho-inspector-ui:builder-alpine

FROM docker.io/library/alpine:3.23

LABEL org.opencontainers.image.title="honcho-inspector-ui:builder-alpine" \
      org.opencontainers.image.description="Honcho Inspector UI APK package builder (Alpine 3.23 + Node 22 + apk mkpkg)" \
      org.opencontainers.image.source="https://github.com/cloudbsdorg/honcho-inspector-ui" \
      org.opencontainers.image.licenses="BSD-3-Clause"

ARG HOST_UID=0
ARG HOST_GID=0

RUN apk add --no-cache \
        nodejs \
        npm \
        shadow \
        bash \
        git \
 && rm -rf /var/cache/apk/*

COPY packaging/build/alpine/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod 0755 /usr/local/bin/entrypoint.sh

RUN node --version \
 && npm --version \
 && apk --version

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD []
