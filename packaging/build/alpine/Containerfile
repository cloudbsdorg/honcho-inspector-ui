# Containerfile for the honcho-inspector-ui Alpine package builder.
#
# Source base image:
#   docker.io/library/alpine:3.22 -- the current Alpine stable
#   release. Alpine is musl-based (vs glibc for the other distros
#   in this matrix), so fpm's gem dependencies and the Node 24
#   binary built for musl must both be installed. Alpine is the
#   smallest base image we use (~5 MB compressed), which keeps the
#   build cache and CI pull bandwidth low.
#
# Why a third-party repo (Alpine edge/community) is added on demand:
#   Alpine 3.22's main + community repos ship Node 22. Angular 22 +
#   the production tooling chain work best on Node 24, which is
#   only in the rolling edge/community repo. We do NOT add
#   edge/community to /etc/apk/repositories permanently -- that
#   would leak edge packages into every later apk invocation in
#   this image. Instead we install nodejs24 with the inline
#   `--repository=http://dl-cdn.alpinelinux.org/alpine/edge/community`
#   flag, which fetches the package index from that URL just for
#   this one `apk add` call. The result: edge packages land in the
#   image but the repo entry does not.
#
# Why `npm` is also pulled explicitly from edge/community:
#   Alpine 3.22 main ships npm 10.x; edge/community has the npm
#   release that ships alongside Node 24 (npm 11.x). Mixing Node 24
#   with the older npm 10 from main produces lockfile-engine
#   warnings on every `npm ci` later, so we keep them paired.
#
# Artifact produced:
#   honcho-inspector-ui-0.1.0-SNAPSHOT.apk (a fpm-built .apk via
#   `fpm -s dir -t apk`). Written to /out at run time via the
#   bind-mount contract:
#
#     podman run --rm \
#       -v $PWD:/src:ro -v $PWD/../dist:/out:rw \
#       --env HOST_UID=$(id -u) --env HOST_GID=$(id -g) \
#       honcho-inspector-ui:builder-alpine
#
#   HOST_UID/HOST_GID default to 0:0; the entrypoint chowns the
#   artifact back to the invoking user.

# ====== build =====================================================
FROM docker.io/library/alpine:3.22

LABEL org.opencontainers.image.title="honcho-inspector-ui:builder-alpine" \
      org.opencontainers.image.description="Honcho Inspector UI APK package builder (Alpine 3.22 + Node 24 + fpm)" \
      org.opencontainers.image.source="https://github.com/cloudbsdorg/honcho-inspector-ui" \
      org.opencontainers.image.licenses="BSD-3-Clause"

ARG HOST_UID=0
ARG HOST_GID=0

# Install in two passes:
#   1. The native build toolchain + Ruby from main -- no edge repo
#      needed; ruby 3.4.4 and build-base are in 3.22 main.
#   2. nodejs24 + npm24 from edge/community via the inline
#      --repository flag (transient repo, not persisted to
#      /etc/apk/repositories).
# We pin to the edge/community URL explicitly so the apk index is
# fetched from the CDN for this install only.
RUN set -eux \
 && apk add --no-cache \
        ruby \
        ruby-dev \
        build-base \
        rpm \
        libffi-dev \
        openssl-dev \
        shadow \
 && apk add --no-cache \
        --repository=http://dl-cdn.alpinelinux.org/alpine/edge/community \
        nodejs \
        npm \
 && gem install --no-document fpm \
 && rm -rf /var/cache/apk/* /root/.gem

# Bake the build entrypoint.
COPY packaging/build/alpine/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod 0755 /usr/local/bin/entrypoint.sh

# Smoke-check the toolchain.
RUN node --version \
 && npm --version \
 && ruby --version \
 && fpm --version

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD []
