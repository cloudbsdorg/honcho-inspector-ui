# Containerfile for the honcho-inspector-ui openSUSE Leap package builder.
#
# Source base image:
#   docker.io/library/opensuse/leap:16.0 -- the current openSUSE
#   Leap release (the community-distribution twin of SUSE Linux
#   Enterprise). Leap 16 ships Node 24 (as `nodejs24` 24.14.1-
#   160000.1.1) in the OSS repo and Ruby 3.4 (as `ruby` + `ruby-devel`)
#   in OSS as well, so the upstream distro tooling covers our needs
#   for both runtimes without third-party shims.
#
# Why a third-party repo (Package Hub) is enabled:
#   openSUSE splits its community package archive into the OSS
#   repo (mainline, fully supported) and Package Hub (community-
#   contributed but openSUSE-built, i.e. not arbitrary user repos).
#   In earlier Leap releases Package Hub was a separate URL; in
#   Leap 16 it is rolled into the same repository pool but must be
#   explicitly enabled via the `zypper mr --enable` /
#   `zypper modifyrepo --enable` call we issue in the RUN step
#   below -- the default zypper config disables Package Hub so
#   that a fresh Leap install does not pull community packages
#   implicitly. Without enabling it, `nodejs24` is invisible.
#
# Artifact produced:
#   honcho-inspector-ui-0.1.0-SNAPSHOT-1.noarch.rpm (a noarch fpm
#   RPM, identical layout to the Rocky 10 build). Written to /out
#   at run time via the bind-mount contract:
#
#     podman run --rm \
#       -v $PWD:/src:ro -v $PWD/../dist:/out:rw \
#       --env HOST_UID=$(id -u) --env HOST_GID=$(id -g) \
#       honcho-inspector-ui:builder-suse
#
#   HOST_UID/HOST_GID default to 0:0; the entrypoint chowns the
#   artifact back to the invoking user.

# ====== build =====================================================
FROM docker.io/opensuse/leap:16.0

LABEL org.opencontainers.image.title="honcho-inspector-ui:builder-suse" \
      org.opencontainers.image.description="Honcho Inspector UI RPM package builder (openSUSE Leap 16 + Node 24 + fpm)" \
      org.opencontainers.image.source="https://github.com/cloudbsdorg/honcho-inspector-ui" \
      org.opencontainers.image.licenses="BSD-3-Clause"

ARG HOST_UID=0
ARG HOST_GID=0

# zypper's auto-refresh is on by default; the docker image's repo
# files already point at the CDN, so a single `zypper --non-interactive
# refresh` followed by install picks up the latest metadata.
# --no-recommends keeps the layer small (no docs, no translations).
#
# rpmlint is intentionally NOT installed: it is not in the Leap 16
# OSS or update repos, and fpm's RPM backend does not require it.
#
# Leap 16's /etc/gemrc has --format-executable on by default,
# which renames the fpm binary to fpm.ruby3.4 (a SUSE convention
# so multiple Ruby versions can co-exist). Pass
# --no-format-executable to install the binary as plain `fpm`.
RUN set -eux \
 && zypper --non-interactive --no-gpg-checks refresh \
 && zypper --non-interactive modifyrepo --enable PackageHub || true \
 && zypper --non-interactive install --no-recommends \
        nodejs24 \
        nodejs24-npm \
        ruby \
        ruby-devel \
        gcc \
        gcc-c++ \
        make \
        rpm-build \
        rpm-devel \
        openssl-devel \
        libffi-devel \
        shadow \
 && gem install --no-document --no-format-executable --bindir /usr/bin fpm \
 && zypper --non-interactive clean --all \
 && rm -rf /var/cache/zypp /var/lib/zypp

# Bake the build entrypoint.
COPY packaging/build/suse/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod 0755 /usr/local/bin/entrypoint.sh

# Smoke-check the toolchain.
RUN node --version \
 && npm --version \
 && ruby --version \
 && fpm --version

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD []
